{
  "name": "aispace",
  "version": "1.0.0",
  "description": "在 AI 能力日益强大的今天，学习新技术的重心应从语法细节转向系统架构、技术选型与设计决策。核心问题不再是“代码怎么写”，而是“为什么这么做”。",
  "homepage": "https://github.com/wangez/aispace#readme",
  "bugs": {
    "url": "https://github.com/wangez/aispace/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangez/aispace.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "init": "cd server && node src/init",
    "node": "cd server && npm run dev",
    "front": "cd front && npm run dev",
    "reset": "cd server && node mongodb/init",
    "docker:build": "docker build -t wnz_agent .",
    "docker:run": "docker run -d -p 3000:3000 -p 8080:8080 -p 27017:27017 --name wnz_agent_wapper wnz_agent",
    "docker:rm": "docker rm -f wnz_agent_wapper",
    "docker:_commit": "docker commit wnz_agent_wapper wnz_agent_with_data:latest",
    "docker:_save": "docker save wnz_agent_with_data:latest | gzip > wnz_agent_with_data.tar.gz",
    "docker:save": "npm run docker:_commit && npm run docker:_save"
  }
}
